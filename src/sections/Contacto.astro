<section
  id="contacto"
  class="min-h-dvh w-full bg-blueRGA px-6 py-16 md:px-12"
>
  <div
    class="mx-auto grid w-full max-w-7xl grid-cols-1 items-center gap-12 lg:grid-cols-[1fr_auto_1fr]"
  >
    <div>
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-white md:text-4xl">
          CONTÁCTANOS
        </h1>

        <h2 class="mt-3 text-lg font-semibold text-white md:text-xl">
          SOLUCIONES PARA INDUSTRIAS
        </h2>

        <p class="mt-4 max-w-2xl leading-7 text-greyRGA">
          Optimice la higiene y seguridad de su empresa con el respaldo de
          Consorcio RGA. Estamos listos para asesorarlo en la elección de los
          mejores insumos químicos, sistemas de limpieza y equipos de protección
          personal adaptados a su sector.
        </p>
      </div>

      <form
        id="contact-form"
        class="flex flex-col gap-6"
      >
        <input
          type="hidden"
          name="access_key"
          value="e1f54b6c-c8a3-4f8a-b18c-322129f8a4b9"
        />

        <input
          type="hidden"
          name="subject"
          value="Nuevo mensaje desde Consorcio RGA"
        />

        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          tabindex="-1"
          autocomplete="off"
        />

        <!-- Mantén aquí tus campos actuales -->

        <button
          id="submit-button"
          type="submit"
          class="w-fit rounded-lg bg-white px-8 py-3 font-semibold text-blueRGA transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60"
        >
          Enviar mensaje
        </button>

        <p
          id="form-status"
          class="hidden rounded-lg px-4 py-3 font-medium"
          aria-live="polite"
        ></p>
      </form>
    </div>

    <!-- Separador -->
    <div class="flex items-center justify-center">
      <div class="hidden h-80 w-px bg-gray-300 lg:block"></div>

      <span
        class="rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-500 lg:absolute"
      >
        O
      </span>
    </div>

    <!-- Información -->
    <div class="text-center lg:text-left">
      <h2 class="text-3xl font-bold text-white">
        INFORMACIÓN
      </h2>

      <div class="mt-8 flex flex-col gap-6 text-greyRGA">
        <div>
          <h3 class="font-semibold text-white">
            Dirección
          </h3>

          <p class="mt-1">
            Av. Monterrico Chico 436, Santiago de Surco
          </p>
        </div>

        <div>
          <h3 class="font-semibold text-white">
            Correo electrónico
          </h3>

          <a
            href="mailto:ventas@consorciorga.com.pe"
            class="mt-1 inline-block hover:underline"
          >
            ventas@consorciorga.com.pe
          </a>
        </div>

        <div>
          <h3 class="font-semibold text-white">
            Teléfono
          </h3>

          <a
            href="tel:+51951171588&"
            class="mt-1 inline-block hover:underline"
          >
            +51 951 171 588
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form =
    document.querySelector<HTMLFormElement>("#contact-form");

  const submitButton =
    document.querySelector<HTMLButtonElement>("#submit-button");

  const formStatus =
    document.querySelector<HTMLParagraphElement>("#form-status");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!submitButton || !formStatus) return;

    submitButton.disabled = true;
    submitButton.textContent = "Enviando...";
    formStatus.className = "hidden";

    try {
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      const response = await fetch(
        "https://api.web3forms.com/submit",
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(data),
        },
      );

      const result = await response.json();

      if (!response.ok || result.success !== true) {
        throw new Error(
          result.message ??
          result.body?.message ??
          `Error HTTP ${response.status}`,
        );
      }

      form.reset();

      formStatus.textContent =
        "Mensaje enviado correctamente. Nos comunicaremos contigo pronto.";

      formStatus.className =
        "rounded-lg bg-green-100 px-4 py-3 font-medium text-green-800";
    } catch (error) {
      console.error("Error enviando formulario:", error);

      const message =
        error instanceof Error
          ? error.message
          : "Error desconocido";

      formStatus.textContent =
        `No se pudo enviar el mensaje: ${message}`;

      formStatus.className =
        "rounded-lg bg-red-100 px-4 py-3 font-medium text-red-800";
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Enviar mensaje";
    }
  });
</script>