<section
  id="contacto"
  class="min-h-dvh w-full bg-blueRGA px-6 py-16 md:px-12"
>
  <div
    class="mx-auto grid w-full max-w-7xl grid-cols-1 items-center gap-12 lg:grid-cols-[1fr_auto_1fr]"
  >
    <div>
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-white md:text-4xl">
          CONTÁCTANOS
        </h1>

        <h2 class="mt-3 text-lg font-semibold text-white md:text-xl">
          SOLUCIONES PARA INDUSTRIAS
        </h2>

        <p class="mt-4 max-w-2xl leading-7 text-greyRGA">
          Optimice la higiene y seguridad de su empresa con el respaldo de
          Consorcio RGA. Estamos listos para asesorarlo en la elección de los
          mejores insumos químicos, sistemas de limpieza y equipos de protección
          personal adaptados a su sector.
        </p>
      </div>

      <form class="flex flex-col gap-6" id="form">
        <input type="hidden" name="access_key" value="e1f54b6c-c8a3-4f8a-b18c-322129f8a4b9" />

        <!-- Nombre -->
        <div class="flex flex-col gap-2">
          <label
            for="fname"
            class="flex items-center gap-1 font-medium text-greyRGA"
          >
            Nombre
            <span class="text-red-500">*</span>
          </label>

          <input
            type="text"
            id="fname"
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 outline-none transition focus:border-greyRGA focus:ring-2 focus:ring-blueRGA/20"
          />
        </div>

        <!-- Correo -->
        <div class="flex flex-col gap-2">
          <label
            for="fcorreo"
            class="flex items-center gap-1 font-medium text-greyRGA"
          >
            Correo electrónico
            <span class="text-red-500">*</span>
          </label>

          <input
            type="email"
            id="fcorreo"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 outline-none transition focus:border-greyRGA focus:ring-2 focus:ring-blueRGA/20"
          />
        </div>

        <!-- Mensaje -->
        <div class="flex flex-col gap-2">
          <label
            for="fmensaje"
            class="flex items-center gap-1 font-medium text-greyRGA"
          >
            Comentario o mensaje
            <span class="text-red-500">*</span>
          </label>

          <textarea
            id="fmensaje"
            name="message"
            rows="5"
            required
            class="w-full resize-none rounded-lg border border-gray-300 bg-white px-4 py-3 outline-none transition focus:border-greyRGA focus:ring-2 focus:ring-blueRGA/20"
          ></textarea>
        </div>

        <button
          id="submit-button"
          type="submit"
          class="w-fit rounded-lg bg-white px-8 py-3 font-semibold text-blueRGA transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60"
        >
          Enviar mensaje
        </button>
        <div
          id="result"
          class="hidden rounded-lg px-6 py-4 font-semibold"
          role="status"
          aria-live="polite"
        ></div>
      </form>
    </div>

    <!-- Separador -->
    <div class="flex items-center justify-center">
      <div class="hidden h-80 w-px bg-gray-300 lg:block"></div>

      <span
        class="rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-500 lg:absolute"
      >
        O
      </span>
    </div>

    <!-- Información -->
    <div class="text-center lg:text-left">
      <h2 class="text-3xl font-bold text-white">
        INFORMACIÓN
      </h2>

      <div class="mt-8 flex flex-col gap-6 text-greyRGA">
        <div>
          <h3 class="font-semibold text-white">
            Dirección
          </h3>

          <p class="mt-1">
            Av. Monterrico Chico 436, Santiago de Surco
          </p>
        </div>

        <div>
          <h3 class="font-semibold text-white">
            Correo electrónico
          </h3>

          <a
            href="mailto:ventas@consorciorga.com.pe"
            class="mt-1 inline-block hover:underline"
          >
            ventas@consorciorga.com.pe
          </a>
        </div>

        <div>
          <h3 class="font-semibold text-white">
            Teléfono
          </h3>

          <a
            href="tel:+51951171588&"
            class="mt-1 inline-block hover:underline"
          >
            +51 951 171 588
          </a>
        </div>
      </div>
    </div>
  </div>
</section>


<script>
  const form = document.querySelector<HTMLFormElement>("#form");
  const result = document.querySelector<HTMLDivElement>("#result");
  const submitButton =
    document.querySelector<HTMLButtonElement>("#submit-button");

  function showLoading(): void {
    if (!result) return;

    result.className =
      "flex items-center gap-3 rounded-lg border border-blue-200 bg-blue-50 px-6 py-4 font-semibold text-blue-800";

    result.innerHTML = `
      <svg
        class="size-5 animate-spin"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"
        ></circle>

        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"
        ></path>
      </svg>

      <span>Enviando mensaje...</span>
    `;
  }

  function showSuccess(): void {
    if (!result) return;

    result.className =
      "flex items-start gap-3 rounded-lg border border-green-300 bg-green-50 px-6 py-4 font-semibold text-green-800";

    result.innerHTML = `
      <svg
        class="mt-0.5 size-6 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="9"></circle>
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m8 12 2.5 2.5L16 9"
        ></path>
      </svg>

      <div>
        <p>Mensaje enviado correctamente.</p>
        <p class="mt-1 text-sm font-normal text-green-700">
          Hemos recibido tu consulta y nos comunicaremos contigo pronto.
        </p>
      </div>
    `;
  }

  function showError(): void {
    if (!result) return;

    result.className =
      "rounded-lg border border-red-300 bg-red-50 px-6 py-4 font-semibold text-red-800";

    result.innerHTML = `
      <div class="flex items-start gap-3">
        <svg
          class="mt-0.5 size-6 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="9"></circle>
          <path
            stroke-linecap="round"
            d="M12 7v6"
          ></path>
          <circle cx="12" cy="17" r="1" fill="currentColor"></circle>
        </svg>

        <div>
          <p>No se pudo enviar el mensaje.</p>

          <p class="mt-1 text-sm font-normal text-red-700">
            Revisa tu conexión e inténtalo nuevamente.
          </p>

          <div class="mt-4 flex flex-wrap gap-3">
            <button
              id="retry-button"
              type="button"
              class="rounded-md bg-red-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-800"
            >
              Intentar nuevamente
            </button>

            <a
              href="https://wa.me/51951171588"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md border border-red-300 bg-white px-4 py-2 text-sm font-semibold text-red-800 transition hover:bg-red-100"
            >
              Contactar por WhatsApp
            </a>
          </div>
        </div>
      </div>
    `;

    const retryButton =
      result.querySelector<HTMLButtonElement>("#retry-button");

    retryButton?.addEventListener("click", () => {
      form?.requestSubmit();
    });
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!submitButton) return;

    submitButton.disabled = true;
    submitButton.textContent = "Enviando...";

    showLoading();

    try {
      const response = await fetch(
        "https://api.web3forms.com/submit",
        {
          method: "POST",
          body: new FormData(form),
        },
      );

      const data = await response.json();

      if (!response.ok || data.success !== true) {
        throw new Error(
          data.message || "No se pudo enviar el formulario",
        );
      }

      form.reset();
      showSuccess();
    } catch (error) {
      console.error("Error al enviar el formulario:", error);
      showError();
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Enviar mensaje";
    }
  });
</script>