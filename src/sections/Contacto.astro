<section
  id="contacto"
  class="min-h-dvh w-full bg-blueRGA px-6 py-16 md:px-12"
>
  <div
    class="mx-auto grid w-full max-w-7xl grid-cols-1 items-center gap-12 lg:grid-cols-[1fr_auto_1fr]"
  >
    <div>
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-white md:text-4xl">
          CONTÁCTANOS
        </h1>

        <h2 class="mt-3 text-lg font-semibold text-white md:text-xl">
          SOLUCIONES PARA INDUSTRIAS
        </h2>

        <p class="mt-4 max-w-2xl leading-7 text-greyRGA">
          Optimice la higiene y seguridad de su empresa con el respaldo de
          Consorcio RGA. Estamos listos para asesorarlo en la elección de los
          mejores insumos químicos, sistemas de limpieza y equipos de protección
          personal adaptados a su sector.
        </p>
      </div>

      <form class="flex flex-col gap-6" id="form">
        <input type="hidden" name="access_key" value="e1f54b6c-c8a3-4f8a-b18c-322129f8a4b9" />

        <!-- Nombre -->
        <div class="flex flex-col gap-2">
          <label
            for="fname"
            class="flex items-center gap-1 font-medium text-greyRGA"
          >
            Nombre
            <span class="text-red-500">*</span>
          </label>

          <input
            type="text"
            id="fname"
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 outline-none transition focus:border-greyRGA focus:ring-2 focus:ring-blueRGA/20"
          />
        </div>

        <!-- Correo -->
        <div class="flex flex-col gap-2">
          <label
            for="fcorreo"
            class="flex items-center gap-1 font-medium text-greyRGA"
          >
            Correo electrónico
            <span class="text-red-500">*</span>
          </label>

          <input
            type="email"
            id="fcorreo"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 outline-none transition focus:border-greyRGA focus:ring-2 focus:ring-blueRGA/20"
          />
        </div>

        <!-- Mensaje -->
        <div class="flex flex-col gap-2">
          <label
            for="fmensaje"
            class="flex items-center gap-1 font-medium text-greyRGA"
          >
            Comentario o mensaje
            <span class="text-red-500">*</span>
          </label>

          <textarea
            id="fmensaje"
            name="message"
            rows="5"
            required
            class="w-full resize-none rounded-lg border border-gray-300 bg-white px-4 py-3 outline-none transition focus:border-greyRGA focus:ring-2 focus:ring-blueRGA/20"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-fit rounded-lg bg-white px-8 py-3 font-semibold text-blueRGA transition hover:opacity-90"
        >
          Enviar mensaje
        </button>
        <div id="result"></div>
      </form>
    </div>

    <!-- Separador -->
    <div class="flex items-center justify-center">
      <div class="hidden h-80 w-px bg-gray-300 lg:block"></div>

      <span
        class="rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-500 lg:absolute"
      >
        O
      </span>
    </div>

    <!-- Información -->
    <div class="text-center lg:text-left">
      <h2 class="text-3xl font-bold text-white">
        INFORMACIÓN
      </h2>

      <div class="mt-8 flex flex-col gap-6 text-greyRGA">
        <div>
          <h3 class="font-semibold text-white">
            Dirección
          </h3>

          <p class="mt-1">
            Av. Monterrico Chico 436, Santiago de Surco
          </p>
        </div>

        <div>
          <h3 class="font-semibold text-white">
            Correo electrónico
          </h3>

          <a
            href="mailto:ventas@consorciorga.com.pe"
            class="mt-1 inline-block hover:underline"
          >
            ventas@consorciorga.com.pe
          </a>
        </div>

        <div>
          <h3 class="font-semibold text-white">
            Teléfono
          </h3>

          <a
            href="tel:+51951171588&"
            class="mt-1 inline-block hover:underline"
          >
            +51 951 171 588
          </a>
        </div>
      </div>
    </div>
  </div>
</section>


<script>
  const form = document.getElementById("form") as HTMLFormElement;
  const result = document.getElementById("result") as HTMLElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    result.innerHTML = "Sending...";

    const response = await fetch("https://api.web3forms.com/submit", {
      method: "POST",
      body: new FormData(form),
    });

    const data = await response.json();
    if (data.success) {
      result.innerHTML = "Form Submitted Successfully";
      form.reset();
    } else {
      result.innerHTML = data.message;
    }
  });
</script>